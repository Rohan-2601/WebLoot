{
  "name": "webloot",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "web",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web & npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=web",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=web",
    "start:web": "npm run start --workspace=web",
    "start:server": "npm run start --workspace=server"
  }
}
